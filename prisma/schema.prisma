// BloodChai - Blood Donation Platform for Bangladesh
// Prisma Schema for PostgreSQL (Supabase/Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Base for all user types
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  role          String    @default("recipient") // admin, donor, recipient
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  donor         Donor?
  recipient     Recipient?
  bloodRequests BloodRequest[]  @relation("Requester")
  reports       Report[]        @relation("Reporter")
  
  @@map("users")
}

// Donor model - Extended profile for blood donors
model Donor {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Personal Info
  bloodGroup      String    // A+, A-, B+, B-, AB+, AB-, O+, O-
  dateOfBirth     String?
  gender          String?   // male, female, other
  profileImage    String?
  
  // Location Info (Bangladesh divisions/districts)
  division        String    // Dhaka, Chittagong, Rajshahi, Khulna, Sylhet, Barisal, Rangpur, Mymensingh
  district        String
  area            String?   // Specific area/neighborhood
  address         String?
  
  // Donation Status
  isAvailable     Boolean   @default(true)
  lastDonationDate DateTime?
  totalDonations  Int       @default(0)
  points          Int       @default(0)  // Reward points
  
  // Emergency contact
  emergencyPhone  String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  donations       Donation[]
  receivedRequests BloodRequest[] @relation("DonorRequests")
  reports         Report[]  @relation("ReportedDonor")
  
  @@map("donors")
}

// Recipient model - Users who need blood
model Recipient {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Location Info
  division      String?
  district      String?
  area          String?
  address       String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  bloodRequests BloodRequest[] @relation("RecipientRequests")
  
  @@map("recipients")
}

// Blood Request model
model BloodRequest {
  id              String    @id @default(cuid())
  
  // Relations
  requesterId     String
  requester       User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipientId     String?
  recipient       Recipient? @relation("RecipientRequests", fields: [recipientId], references: [id], onDelete: SetNull)
  donorId         String?
  donor           Donor?    @relation("DonorRequests", fields: [donorId], references: [id], onDelete: SetNull)
  
  // Request Details
  bloodGroup      String
  patientName     String
  hospitalName    String
  hospitalAddress String
  contactNumber   String
  urgency         String    // critical, urgent, normal
  notes           String?
  
  // Status
  status          String    @default("pending") // pending, accepted, declined, completed, cancelled
  isEmergency     Boolean   @default(false)
  
  // Response
  donorResponse   String?   // accept, decline
  donorResponseAt DateTime?
  declineReason   String?
  
  // Completion
  completedAt     DateTime?
  approvedByRecipient Boolean @default(false)
  approvedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("blood_requests")
}

// Donation model - Track successful donations
model Donation {
  id              String    @id @default(cuid())
  donorId         String
  donor           Donor     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  requestId       String?   @unique
  bloodGroup      String
  recipientName   String?
  hospitalName    String?
  donationDate    DateTime  @default(now())
  pointsEarned    Int       @default(10)  // Points earned for this donation
  
  createdAt       DateTime  @default(now())
  
  @@map("donations")
}

// Blood Bank model
model BloodBank {
  id              String    @id @default(cuid())
  name            String
  division        String
  district        String
  address         String
  phone           String?
  email           String?
  operatingHours  String?
  services        String?   // JSON string of services offered
  mapUrl          String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("blood_banks")
}

// Report model - Recipients can report donors
model Report {
  id              String    @id @default(cuid())
  reporterId      String
  reporter        User      @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedDonorId String
  reportedDonor   Donor     @relation("ReportedDonor", fields: [reportedDonorId], references: [id], onDelete: Cascade)
  requestId       String?   // Related blood request
  
  reason          String
  description     String?
  status          String    @default("pending") // pending, reviewed, resolved, dismissed
  adminNotes      String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("reports")
}

// Notice model - For both frontend and donor dashboard
model Notice {
  id              String    @id @default(cuid())
  title           String
  content         String
  type            String    @default("general") // general, emergency, event
  targetAudience  String    @default("all") // all, donors, recipients
  isActive        Boolean   @default(true)
  isPinned        Boolean   @default(false)
  expiresAt       DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("notices")
}

// Payment Configuration model
model PaymentConfig {
  id              String    @id @default(cuid())
  method          String    @unique // bkash, nagad, bank
  accountName     String
  accountNumber   String
  instructions    String    // How to donate
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("payment_configs")
}

// Rulebook model
model Rulebook {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique // blood-donation-rules, reward-rules
  content         String    // Markdown content
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("rulebooks")
}

// Money Donation model - Track donations to the platform
model MoneyDonation {
  id              String    @id @default(cuid())
  donorName       String
  donorEmail      String?
  donorPhone      String?
  amount          Float
  paymentMethod   String    // bkash, nagad, bank
  transactionId   String?
  status          String    @default("pending") // pending, confirmed, rejected
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("money_donations")
}

// Emergency Callout model
model EmergencyCallout {
  id              String    @id @default(cuid())
  bloodGroup      String
  location        String
  hospitalName    String
  contactNumber   String
  description     String?
  status          String    @default("active") // active, resolved, cancelled
  resolvedAt      DateTime?
  resolvedBy      String?   // Admin who resolved
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("emergency_callouts")
}

// Session model for NextAuth
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  @@map("sessions")
}

// Verification Token model for NextAuth
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Account model for NextAuth
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Site Configuration model - For footer and site settings
model SiteConfig {
  id              String    @id @default(cuid())
  key             String    @unique // "footer", "contact", "social"
  value           String    @db.Text // JSON string containing the config
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("site_configs")
}
