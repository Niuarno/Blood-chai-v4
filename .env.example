# BloodChai Environment Variables
# Copy this file to .env for local development

# ===========================================
# DATABASE CONFIGURATION (SUPABASE)
# ===========================================
# Get these from Supabase Dashboard → Settings → Database → Connection string

# DATABASE_URL - Use the "Transaction pooler" URL (Port 6543)
# This is for serverless environments like Vercel
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# DIRECT_DATABASE_URL - Use the "Direct connection" URL (Port 5432)
# This is for migrations and Prisma Studio
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-32-character-secret-key-here"

# Your app URL
NEXTAUTH_URL="http://localhost:3000"
# For production: NEXTAUTH_URL="https://your-app.vercel.app"

# ===========================================
# OPTIONAL: NODE_ENV
# ===========================================
NODE_ENV="development"
